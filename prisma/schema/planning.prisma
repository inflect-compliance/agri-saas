// ═══════════════════════════════════════════════════════════════════
//  CROP PLANNING DOMAIN — succession planning + plan-vs-actual
// ═══════════════════════════════════════════════════════════════════
//
//  GAP-09 multi-file schema: new domain file. Generator + datasource
//  remain in base.prisma. Conventions mirror agriculture.prisma:
//    • cuid ids, createdAt/updatedAt, soft-delete trio
//      (deletedAt / deletedByUserId / retentionUntil — bare scalars).
//    • Cross-tenant barrier `@@unique([id, tenantId])` on every parent;
//      child FKs are composite `[xId, tenantId] → [id, tenantId]`.
//    • Every tenant-scoped table gets the canonical RLS trio
//      (tenant_isolation + tenant_isolation_insert + superuser_bypass +
//      FORCE) in the migration — rls-coverage derives the set from the
//      DMMF and fails CI otherwise. Every model here has a NON-NULL
//      tenantId, so all use the standard split-policy form (none belong
//      in SINGLE_POLICY_EXCEPTIONS).
//    • The succession MATH is not here — it lives in the pure engine
//      `src/lib/planning/succession.ts`. These models persist its inputs
//      (CropPlan config + merged CropType/CropVariety defaults) and its
//      outputs (Planting rows).
//
//  Back-relations added elsewhere (Prisma needs both sides):
//    • auth.prisma   Tenant:   cropTypes / cropVarieties / seasons /
//                              cropPlans / plantings / logPlantings
//    • journal.prisma LogEntry: plantings LogPlanting[]
//    • agriculture.prisma Location: cropPlans / plantings
//    • agriculture.prisma Parcel:   plantings
// ═══════════════════════════════════════════════════════════════════

/// Tenant crop catalog — a crop the farm grows (Tomato, Lettuce, …).
/// Tenant-scoped (like Item) so each farm curates its own list; seeded
/// from OpenFarm CC0 defaults. The agronomic numbers live on CropVariety.
model CropType {
  id              String    @id @default(cuid())
  tenantId        String
  key             String?
  name            String
  family          String? // botanical family, e.g. "Solanaceae"
  category        String? // loose grouping, e.g. "fruiting", "leafy green"
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?

  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  varieties CropVariety[]
  cropPlans CropPlan[]

  @@unique([id, tenantId])
  @@unique([tenantId, key])
  @@index([tenantId, name])
}

/// A variety of a CropType — carries the succession-engine defaults
/// (days-to-maturity, spacing, seed size). Seeded from OpenFarm CC0;
/// `sourceUrn` records provenance. Tenant-scoped catalog.
model CropVariety {
  id                  String          @id @default(cuid())
  tenantId            String
  cropTypeId          String
  key                 String?
  name                String
  defaultMethod       PlantingMethod?
  daysToGermination   Int?
  /// Sow → transplant, in days (TRANSPLANT varieties).
  daysToTransplant    Int?
  /// Days to first harvest (from transplant, or from sow for direct-sow).
  daysToMaturity      Int?
  harvestWindowDays   Int?
  inRowSpacingCm      Decimal?        @db.Decimal(8, 2)
  betweenRowSpacingCm Decimal?        @db.Decimal(8, 2)
  seedsPerGram        Decimal?        @db.Decimal(10, 2)
  /// Expected germination 0..1 (seed-quantity overage).
  germinationRate     Decimal?        @db.Decimal(4, 3)
  seedsPerCell        Int?
  /// Agronomic soil preferences for soil-aware SUITABILITY (advisory
  /// only). Optional JSON so a variety with no curated defaults yields
  /// an honest "unknown" suitability rather than a fabricated number:
  /// { phMin?, phMax?, texturePreference?: string[], drainagePreference? }.
  /// Thresholds come from catalog/import data — never invented at runtime.
  soilDefaultsJson    Json?
  /// OpenFarm (CC0) or other provenance URN.
  sourceUrn           String?
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?
  deletedByUserId     String?
  retentionUntil      DateTime?

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  cropType  CropType   @relation(fields: [cropTypeId, tenantId], references: [id, tenantId], onDelete: Cascade)
  cropPlans CropPlan[]
  plantings Planting[]

  @@unique([id, tenantId])
  @@unique([tenantId, cropTypeId, key])
  @@index([tenantId, cropTypeId])
  @@index([tenantId, name])
}

/// A planting season window (e.g. "2026 Main Season"). Tenant-scoped.
model Season {
  id              String       @id @default(cuid())
  tenantId        String
  key             String?
  name            String
  year            Int?
  startDate       DateTime
  endDate         DateTime
  status          SeasonStatus @default(PLANNING)
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  cropPlans    CropPlan[]
  contracts    Contract[]
  yieldRecords YieldRecord[]

  @@unique([id, tenantId])
  @@unique([tenantId, key])
  @@index([tenantId, status])
  @@index([tenantId, startDate])
}

/// A crop plan within a season — the succession CONFIG the engine
/// (`src/lib/planning/succession.ts`) expands into Planting rows.
/// Tenant-scoped.
model CropPlan {
  id                  String         @id @default(cuid())
  tenantId            String
  seasonId            String
  cropTypeId          String
  cropVarietyId       String?
  locationId          String?
  // #9 — a plan can target a specific parcel within its location. Nullable:
  // a plan may still be location-level (or unscoped) when no parcel is picked.
  parcelId            String?
  name                String
  method              PlantingMethod @default(DIRECT_SOW)
  firstSowDate        DateTime
  successions         Int            @default(1)
  intervalDays        Int            @default(0)
  // Allocation, per succession (drives plant count + seed quantity).
  plantsPerSuccession Int?
  bedLengthM          Decimal?       @db.Decimal(10, 2)
  rowsPerBed          Int?
  targetAreaM2        Decimal?       @db.Decimal(12, 2)
  status              CropPlanStatus @default(DRAFT)
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?
  deletedByUserId     String?
  retentionUntil      DateTime?

  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  season    Season       @relation(fields: [seasonId, tenantId], references: [id, tenantId], onDelete: Cascade)
  cropType  CropType     @relation(fields: [cropTypeId, tenantId], references: [id, tenantId])
  variety   CropVariety? @relation(fields: [cropVarietyId, tenantId], references: [id, tenantId])
  location  Location?    @relation(fields: [locationId, tenantId], references: [id, tenantId])
  parcel    Parcel?      @relation(fields: [parcelId, tenantId], references: [id, tenantId])
  plantings Planting[]

  @@unique([id, tenantId])
  @@index([tenantId, seasonId])
  @@index([tenantId, cropTypeId])
  @@index([tenantId, cropVarietyId])
  @@index([tenantId, locationId])
  @@index([tenantId, parcelId])
  @@index([tenantId, status])
}

/// One succession instance — engine-generated, with PLANNED dates +
/// computed seed/allocation. Actual sow/transplant/harvest come from
/// linked journal LogEntries (LogPlanting). Tenant-scoped.
model Planting {
  id                String         @id @default(cuid())
  tenantId          String
  cropPlanId        String
  cropVarietyId     String?
  locationId        String?
  parcelId          String?
  successionNumber  Int
  method            PlantingMethod
  // PLANNED dates from the succession engine.
  sowDate           DateTime?
  transplantDate    DateTime?
  harvestStartDate  DateTime?
  harvestEndDate    DateTime?
  seedQuantityGrams Decimal?        @db.Decimal(12, 2)
  plantCount        Int?
  areaM2            Decimal?        @db.Decimal(12, 2)
  status            PlantingStatus  @default(PLANNED)
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  deletedByUserId   String?
  retentionUntil    DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  cropPlan     CropPlan      @relation(fields: [cropPlanId, tenantId], references: [id, tenantId], onDelete: Cascade)
  variety      CropVariety?  @relation(fields: [cropVarietyId, tenantId], references: [id, tenantId])
  location     Location?     @relation(fields: [locationId, tenantId], references: [id, tenantId])
  parcel       Parcel?       @relation(fields: [parcelId, tenantId], references: [id, tenantId])
  logPlantings LogPlanting[]
  agroSignals  AgroSignal[]
  yieldRecords YieldRecord[]

  @@unique([id, tenantId])
  @@index([tenantId, cropPlanId])
  @@index([tenantId, cropVarietyId])
  @@index([tenantId, locationId])
  @@index([tenantId, parcelId])
  @@index([tenantId, status])
  @@index([tenantId, sowDate])
}

/// Plan-vs-actual link — a journal LogEntry recording the ACTUAL
/// sow/transplant/harvest of a Planting. Mirrors LogLocation/LogEquipment.
/// The LogEntry's occurredAt is the actual date; `stage` names which
/// planned date it realises. Tenant-scoped.
model LogPlanting {
  id         String        @id @default(cuid())
  tenantId   String
  logEntryId String
  plantingId String
  stage      PlantingStage
  createdAt  DateTime      @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  logEntry LogEntry @relation(fields: [logEntryId, tenantId], references: [id, tenantId], onDelete: Cascade)
  planting Planting @relation(fields: [plantingId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([logEntryId, plantingId, stage])
  @@index([tenantId, plantingId])
  @@index([tenantId, logEntryId])
}
