// ─────────────────────────────────────────────────────────────────────
// Market-price domain — GLOBAL, tenant-agnostic price cache.
//
// Generator + datasource remain in base.prisma; this file holds only the
// market-price model blocks. These tables are GLOBAL (no `tenantId`
// column), the same class as SoilSample / CadastreArchive / Unit: the
// cached price series are public reference data (EC AGRI-food open API,
// Alpha Vantage) or a k-anonymised cross-tenant aggregate — identical for
// every tenant. Because they carry no `tenantId`, the DMMF RLS
// auto-enroller in src/lib/db/rls-middleware.ts leaves them out of
// TENANT_SCOPED_MODELS — there is deliberately NO per-tenant RLS filter,
// exactly like `SoilSample`.
//
// The `source:'listings'` series is a cross-tenant WEEKLY MEDIAN over all
// tenants' ACTIVE ExchangeListings, suppressed below a k-anonymity floor
// of 3 distinct tenants — it stores only `{ count }` in point meta, never
// a listing id or tenant id. See src/app-layer/jobs/market-prices-pull.ts.
// ─────────────────────────────────────────────────────────────────────

/// GLOBAL cache of one market-price time series (NO tenantId — public
/// reference data / k-anonymised aggregate, identical for every tenant,
/// exactly like `SoilSample`). A series is the natural grouping the read
/// API splits a chart by: (source, commodity, region, stage). Upserted
/// idempotently on that natural key. `currency` + `unit` are per-series
/// and load-bearing — the EC oilseeds endpoint reports national-currency
/// prices (BG→BGN, RO→RON), so we NEVER normalise; the chart splits by
/// unit/currency instead.
model MarketPriceSeries {
  id        String   @id @default(cuid())
  /// Data origin: 'ec-agrifood' | 'alpha-vantage' | 'listings'.
  source    String
  /// Commodity slug: 'wheat' | 'maize' | 'barley' | 'sunflower'.
  commodity String
  /// Region: 'BG' | 'RO' | 'EL' | 'EU' | 'GLOBAL'.
  region    String
  /// Optional market stage (EC `stageName` / `marketStage`), e.g. a
  /// delivery/processing stage. Null for sources with no stage concept
  /// (Alpha Vantage, listings index).
  stage     String?
  /// Optional human label (product name / reference note).
  label     String?
  /// Price unit as reported by the source, e.g. 'EUR/t', 'USD/bu',
  /// 'BGN/t'. NOT normalised across sources.
  unit      String
  /// ISO currency of `price`, e.g. 'EUR' | 'BGN' | 'RON' | 'USD'.
  currency  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  points MarketPricePoint[]

  /// Natural key — one series per (source, commodity, region, stage) so
  /// the pull job upserts idempotently.
  @@unique([source, commodity, region, stage])
}

/// GLOBAL dated observation on a MarketPriceSeries (NO tenantId — see the
/// series doc). Upserted idempotently on (seriesId, date) so re-running
/// the pull never duplicates a point.
model MarketPricePoint {
  id        String            @id @default(cuid())
  seriesId  String
  series    MarketPriceSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  /// Observation date (week-ending / month / day, per source). Date-only.
  date      DateTime          @db.Date
  price     Decimal           @db.Decimal(12, 2)
  /// Structured provenance — e.g. `{ count }` for the k-anonymised
  /// listings index (distinct-tenant count, never ids). Never free text.
  meta      Json?
  createdAt DateTime          @default(now())

  /// Idempotent-upsert key.
  @@unique([seriesId, date])
  /// FK index (schema-index Layer B).
  @@index([seriesId])
}

/// GLOBAL cache of one aggregated agricultural-news headline (NO tenantId —
/// public reference data aggregated from free Bulgarian agri RSS/Atom feeds +
/// ДФ Земеделие + EC agri press, identical for every tenant, exactly like
/// `MarketPriceSeries` / `SoilSample`). Feeds the Trends → News tab. Upserted
/// idempotently on `guidHash` (sha256 of the item's guid‖link) so a re-run of
/// the daily `market-news-pull` job never duplicates a headline; the job also
/// prunes rows whose `publishedAt` is older than 60 days.
model MarketNewsItem {
  id String @id @default(cuid())
  /// Origin feed slug, e.g. 'agri-bg' | 'dfz' | 'ec-agrifood'.
  source String
  /// Bucket the News tab filters by: 'market' | 'policy' | 'general'. Assigned
  /// by the feed's default category, promoted by a deterministic BG+EN keyword
  /// match (see src/lib/news/categorize.ts).
  category String
  /// Headline text (plain, sanitised — never raw HTML).
  title String
  /// Short excerpt from the feed description (plain, sanitised). Nullable —
  /// some feeds ship title-only items.
  summary String?
  /// Canonical article URL — the tap-through target.
  url String
  /// Optional lead image (RSS enclosure / media:content).
  imageUrl String?
  /// Publish time from the feed (pubDate / atom:updated). Drives feed order.
  publishedAt DateTime
  /// Idempotent-upsert + dedupe key: sha256(guid || link).
  guidHash String
  /// Last time the pull saw this item (refreshed on every upsert).
  fetchedAt DateTime @default(now())
  /// First time the pull ingested this item.
  createdAt DateTime @default(now())

  /// Idempotent-upsert / dedupe key.
  @@unique([guidHash])
  /// Backs the News read: filter by category, newest first.
  @@index([category, publishedAt])
  /// Backs the all-categories read: newest first + the 60-day prune scan.
  @@index([publishedAt])
}
