// ═══════════════════════════════════════════════════════════════════
//  JOURNAL DOMAIN — Phase 1: the field record (LogEntry + LogQuantity)
// ═══════════════════════════════════════════════════════════════════
//
//  Design lineage: farmOS log-type ontology + Quantity (GPL-2.0 —
//  CONCEPTS ONLY, reimplemented; no code copied; license-hygiene
//  guardrail enforces).
//
//  Phase-1 scope is deliberately narrow: enough journal to make a spray
//  job a compliant, inventory-accurate field record. When an
//  OperationParcel is marked DONE the field-operation usecase emits one
//  INPUT_APPLICATION LogEntry (the spray record) + a LogQuantity (the
//  applied amount), and the StockTransaction it drives points back at
//  the LogEntry. The full journal (LogLocation/LogEquipment/LogPlanting
//  /LogEntryFile link tables, a quick-entry UI, PLANNED-as-task) is
//  deferred — see docs/implementation-notes for the cut line.
//
//  Back-relations added elsewhere (Prisma needs both sides):
//    • auth.prisma        Tenant:   logEntries LogEntry[]
//    • auth.prisma        User:     LogEntryCreator
//    • agriculture.prisma OperationParcel: logEntries LogEntry[]
//    • agriculture.prisma Unit:     logQuantities LogQuantity[]
//    • inventory.prisma   StockTransaction.logEntry → LogEntry
// ═══════════════════════════════════════════════════════════════════

/// A field event — the durable record of work done (or planned) on the
/// farm. INPUT_APPLICATION is the traceability-critical spray/fertiliser
/// record; free text runs through sanitizePlainText() at the usecase
/// boundary like every write path (Epic D.2).
model LogEntry {
  id                String         @id @default(cuid())
  tenantId          String
  type              LogEntryType
  status            LogEntryStatus @default(DONE)
  /// When the event happened. Time matters for spray records.
  occurredAt        DateTime
  title             String
  notes             String?
  /// Spray-record compliance fields (wind, temp, operator cert no.,
  /// REI/PHI). JSON until the certification module promotes what
  /// schemes require.
  conditionsJson    Json?
  /// The spray prescription line this record was emitted from (simple
  /// FK — OperationParcel has no [id, tenantId] barrier). Lets the job
  /// answer "what did this application consume?".
  operationParcelId String?
  /// Ekylibre intervention-cost concept (reimplemented): optional
  /// cost of this field event, for per-activity costing later.
  costAmount        Decimal?       @db.Decimal(14, 2)
  costCurrency      String?
  /// Free-form structured attributes (e.g. the async photo pest/disease
  /// ID result under `pestId`). Distinct from `conditionsJson` (spray
  /// compliance fields).
  attributesJson    Json?
  /// "Try it with sample data" tag — see Location.isSampleData
  /// (agriculture.prisma). Default-false; reversible via clearSampleData.
  isSampleData      Boolean        @default(false)
  /// Offline exactly-once handle. When a journal entry is created from the
  /// queued outbox, the client's outbox-item id rides in as the
  /// `Idempotency-Key`; a replayed write (flaky rural LTE re-send) dedupes on
  /// (tenantId, clientMutationId) and returns the original entry instead of a
  /// duplicate. Nullable + NULLS-DISTINCT: online creates without a key are
  /// unconstrained (every NULL is unique to Postgres). Mirrors Task.clientMutationId.
  clientMutationId  String?
  createdByUserId   String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?
  deletedByUserId   String?

  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  operationParcel OperationParcel?   @relation(fields: [operationParcelId], references: [id])
  createdBy       User?              @relation("LogEntryCreator", fields: [createdByUserId], references: [id])
  quantities      LogQuantity[]
  stockTx         StockTransaction[]
  locations       LogLocation[]
  equipment       LogEquipment[]
  files           LogEntryFile[]
  /// Plan-vs-actual links — this entry realises a planting milestone.
  plantings       LogPlanting[]
  /// Lot-genealogy edges recorded by a HARVEST entry (provenance link).
  lotLinks        LotLink[]

  @@unique([id, tenantId])
  // Offline idempotency ledger — a replayed journal-entry create dedupes here.
  // Nullable column ⇒ NULLS DISTINCT ⇒ online (no-key) creates never collide;
  // only real Idempotency-Key replays are constrained. Mirrors Task.
  @@unique([tenantId, clientMutationId])
  @@index([tenantId, type, occurredAt])
  @@index([tenantId, status, occurredAt])
  @@index([tenantId, operationParcelId])
}

/// farmOS Quantity: measure + value + unit + label. A spray record
/// carries the applied amount (e.g. { VOLUME 42.5 "L applied" }).
/// Cascade-deleted with its LogEntry.
model LogQuantity {
  id         String          @id @default(cuid())
  tenantId   String
  logEntryId String
  measure    QuantityMeasure
  value      Decimal         @db.Decimal(18, 6)
  unitId     String
  label      String?

  logEntry LogEntry @relation(fields: [logEntryId, tenantId], references: [id, tenantId], onDelete: Cascade)
  unit     Unit     @relation("LogQuantityUnit", fields: [unitId], references: [id])

  @@index([tenantId, logEntryId])
  @@index([tenantId, unitId])
}

/// Tenant-scoped farm equipment (tractor, sprayer, drill, …) that field
/// work is logged against. Generalised from the Asset pattern — the AG
/// equipment register, distinct from the compliance Asset (a Prisma
/// model rename is deliberately deferred). RLS trio in the migration.
model Equipment {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  category        String?
  make            String?
  model           String?
  serialNumber    String?
  year            Int?
  meterValue      Decimal?  @db.Decimal(12, 1)
  attributesJson  Json?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?

  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  createdBy User?          @relation("EquipmentCreator", fields: [createdByUserId], references: [id])
  logLinks  LogEquipment[]

  @@unique([id, tenantId])
  @@index([tenantId, category])
  @@index([tenantId, name])
}

/// Link: a LogEntry happened at a Location (the Feature-1 field block).
model LogLocation {
  id         String @id @default(cuid())
  tenantId   String
  logEntryId String
  locationId String

  logEntry LogEntry @relation(fields: [logEntryId, tenantId], references: [id, tenantId], onDelete: Cascade)
  location Location @relation(fields: [locationId, tenantId], references: [id, tenantId])
  tenant   Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([logEntryId, locationId])
  @@index([tenantId, locationId])
}

/// Link: a LogEntry used a piece of Equipment.
model LogEquipment {
  id          String @id @default(cuid())
  tenantId    String
  logEntryId  String
  equipmentId String

  logEntry  LogEntry  @relation(fields: [logEntryId, tenantId], references: [id, tenantId], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId, tenantId], references: [id, tenantId])
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([logEntryId, equipmentId])
  @@index([tenantId, equipmentId])
}

/// Link: a photo / document attached to a LogEntry via the existing
/// FileRecord pipeline (HortusFox-style photo logging). FileRecord has
/// no [id, tenantId] barrier → simple FK; isolation via tenantId + RLS.
model LogEntryFile {
  id           String   @id @default(cuid())
  tenantId     String
  logEntryId   String
  fileRecordId String
  caption      String?
  createdAt    DateTime @default(now())

  logEntry   LogEntry   @relation(fields: [logEntryId, tenantId], references: [id, tenantId], onDelete: Cascade)
  fileRecord FileRecord @relation("LogEntryFileRecord", fields: [fileRecordId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@unique([logEntryId, fileRecordId])
  @@index([tenantId, logEntryId])
}
