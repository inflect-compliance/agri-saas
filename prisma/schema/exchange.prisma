// ─────────────────────────────────────────────────────────────────────
// Exchange domain — cross-tenant agriculture marketplace.
//
// Generator + datasource remain in base.prisma; this file holds only the
// Exchange model blocks. The Exchange DELIBERATELY breaks the normal
// one-tenant-per-row rule: tenants must read EACH OTHER's offers, so these
// tables are GLOBAL (no `tenantId` column), the same class as Unit /
// Framework / Org*. Because they carry no `tenantId`, the DMMF RLS
// auto-enroller in src/lib/db/rls-middleware.ts leaves them out of
// TENANT_SCOPED_MODELS — reads are global, no per-tenant RLS filter.
//
// Cross-tenant WRITE safety therefore CANNOT rely on RLS. It is enforced
// exclusively at the usecase layer (src/app-layer/usecases/exchange.ts):
// every mutation asserts ctx.tenantId === listing.sellerTenantId. The
// `sellerTenantId` / `inquirerTenantId` columns are PLAIN foreign keys
// (they hold a Tenant.id) — intentionally NOT declared as Prisma
// `@relation`s, so the tables stay decoupled and global and so the
// FK-index guardrail (Layer B) doesn't force tenant-composite indexes.
// ─────────────────────────────────────────────────────────────────────

/// Global cross-tenant marketplace offer (no tenantId → not tenant-scoped,
/// no RLS). A SELL listing offers a commodity; a BUY listing seeks one.
/// `description` + `sellerDisplayName` are PUBLIC, sanitized plaintext
/// (NOT encrypted — every tenant can read them). Write access is guarded in
/// the usecase layer by `ctx.tenantId === sellerTenantId`.
model ExchangeListing {
  id                String                @id @default(cuid())
  /// Owning tenant — plain FK to Tenant.id (NOT a tenantId RLS column).
  sellerTenantId    String
  /// User within the seller tenant who created the listing.
  sellerUserId      String
  side              ExchangeSide
  commodity         String
  quantityTonnes    Decimal               @db.Decimal(14, 3)
  pricePerTonne     Decimal?              @db.Decimal(12, 2)
  priceCurrency     String                @default("BGN")
  /// Bulgaria oblast code (ISO 3166-2 style, e.g. "BG-16") — see
  /// src/lib/geo/bulgaria-regions.ts.
  regionCode        String
  regionName        String
  lat               Float
  lon               Float
  /// PUBLIC blurb — sanitized plaintext, NOT encrypted.
  description       String?
  /// Opt-in public seller name (a tenant may stay anonymous).
  sellerDisplayName String?
  status            ExchangeListingStatus @default(ACTIVE)
  expiresAt         DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  inquiries ExchangeInquiry[]

  @@index([sellerTenantId])
  @@index([side, status])
  @@index([regionCode])
  @@index([status, expiresAt])
}

/// Global cross-tenant inquiry against an ExchangeListing (no tenantId →
/// not tenant-scoped, no RLS). Written by a tenant OTHER than the listing
/// seller (the usecase forbids inquiring on your own listing). `message`
/// is sanitized plaintext. `inquirerTenantId` is a plain FK to Tenant.id.
model ExchangeInquiry {
  id               String                @id @default(cuid())
  listingId        String
  /// Inquiring tenant — plain FK to Tenant.id (NOT a tenantId RLS column).
  inquirerTenantId String
  inquirerUserId   String
  message          String
  quantityTonnes   Decimal?              @db.Decimal(14, 3)
  status           ExchangeInquiryStatus @default(PENDING)
  createdAt        DateTime              @default(now())

  listing ExchangeListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([inquirerTenantId])
}
