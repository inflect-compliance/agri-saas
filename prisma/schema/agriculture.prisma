// ═══════════════════════════════════════════════════════════════════
//  AGRICULTURE DOMAIN — Feature 1: spray-prescription map module
// ═══════════════════════════════════════════════════════════════════
//
//  GAP-09 multi-file schema: new domain file. Generator + datasource
//  remain in base.prisma.
//
//  House conventions mirrored from compliance.prisma:
//    • cuid ids, createdAt/updatedAt, soft-delete trio
//      (deletedAt / deletedByUserId / retentionUntil).
//    • Cross-tenant row barrier `@@unique([id, tenantId])` on tenant
//      parents I own (Location, Parcel, Item), with composite child
//      FKs `[xId, tenantId] → [id, tenantId]`. Task lacks that barrier
//      (only `@@unique([tenantId, key])`), so OperationParcel→Task is
//      a simple FK; tenant isolation there is enforced by RLS + the
//      OperationParcel.tenantId column.
//    • Every tenant-scoped table (tenantId column) gets the canonical
//      RLS trio (tenant_isolation + tenant_isolation_insert +
//      superuser_bypass + FORCE) in the migration. The rls-coverage
//      guardrail derives the tenant-scoped set from the DMMF and will
//      fail CI otherwise. `Unit` has NO tenantId (global catalog) →
//      no RLS, intentionally.
//
//  Geometry: PostGIS via `Unsupported(...)`. Prisma never reads/writes
//  it through the client — all spatial SQL lives in `src/lib/db/geo.ts`.
//  The `postgis` extension is created by the migration (we do not use
//  the datasource `extensions` preview feature, so the CREATE EXTENSION
//  is hand-authored at the top of the migration).
//
//  Back-relations added elsewhere (Prisma needs both sides):
//    • auth.prisma   Tenant: locations / parcels / items / operationParcels
//    • auth.prisma   User:   LocationOwner / LocationCreator /
//                            ItemCreator / OperationParcelCompleter
//    • compliance.prisma Task:       operationParcels OperationParcel[]
//    • compliance.prisma FileRecord: locationSpatialFiles Location[]
//                                    @relation("LocationSpatialFile")
// ═══════════════════════════════════════════════════════════════════

/// Global unit-of-measure catalog (no tenantId → not tenant-scoped,
/// no RLS). Seeded by scripts/import-units.ts. A spray dose is a RATE
/// unit (e.g. "L/ha"); product default units are VOLUME/WEIGHT/COUNT.
model Unit {
  id        String          @id @default(cuid())
  key       String          @unique // "l-per-ha", "kg", "l"
  name      String
  symbol    String
  measure   QuantityMeasure
  createdAt DateTime        @default(now())

  itemsDefault      Item[]             @relation("ItemDefaultUnit")
  doseLines         OperationParcel[]  @relation("OperationParcelDoseUnit")
  waterLines        OperationParcel[]  @relation("OperationParcelWaterUnit")
  invLots           InventoryLot[]     @relation("InventoryLotUnit")
  stockTransactions StockTransaction[] @relation("StockTransactionUnit")
  logQuantities     LogQuantity[]      @relation("LogQuantityUnit")
}

/// GLOBAL agriculture-events catalogue (#15) — fairs, trainings, webinars,
/// subsidy deadlines. NO tenantId (like `Unit`) → not tenant-scoped, no RLS:
/// every tenant reads the same shared list. Seeded (scripts) / admin-posted.
/// `category` is a free String from the curated set fair/training/webinar/
/// subsidy-deadline. A per-tenant event dimension is a future extension.
model AgriEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  /// Curated category: "fair" | "training" | "webinar" | "subsidy-deadline".
  category    String    @default("fair")
  startsAt    DateTime
  endsAt      DateTime?
  place       String?
  url         String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([startsAt])
}

/// Tenant-scoped input-product catalog (the structured spray product).
/// Feature 1 exercises PESTICIDE/FERTILIZER; other categories are the
/// seed of the full inventory module. attributesJson carries
/// regulatory metadata (active ingredient, REI/PHI) until promoted.
model Item {
  id              String       @id @default(cuid())
  tenantId        String
  name            String
  category        ItemCategory
  sku             String?
  defaultUnitId   String
  /// Low-stock alert threshold in defaultUnit (InvenTree pattern). The
  /// lots list surfaces "low stock" when SUM(lot.quantityOnHand) drops
  /// below it; null disables the check.
  reorderLevel    Decimal?     @db.Decimal(14, 3)
  /// БАБХ farm-record regulatory fields (structured, not attributesJson —
  /// the ДНЕВНИК generator reads these directly). quarantinePeriodDays is
  /// the карантинен срок на ПРЗ; "най-ранна дата за прибиране" is computed
  /// as completedAt + quarantinePeriodDays at generation time.
  quarantinePeriodDays Int?
  activeIngredient     String?
  pppRegistrationNo    String?
  attributesJson  Json?
  createdByUserId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  defaultUnit    Unit              @relation("ItemDefaultUnit", fields: [defaultUnitId], references: [id])
  createdBy      User?             @relation("ItemCreator", fields: [createdByUserId], references: [id])
  operationLines OperationParcel[]
  lots           InventoryLot[]

  @@unique([id, tenantId])
  @@index([tenantId, category])
  @@index([tenantId, name])
}

/// The farm/field block a farmer uploads a spatial file into. Shaped
/// after the Asset model (key, name, owner, status, soft-delete).
/// Holds the original uploaded FileRecord + a cached bounding box for
/// map fit; the parcels themselves are child rows.
model Location {
  id              String         @id @default(cuid())
  tenantId        String
  key             String?
  name            String
  description     String?
  status          LocationStatus @default(ACTIVE)
  /// Enterprise-grain: physical kind. FIELD (default) is a growing area;
  /// BIN/STORAGE hold harvested produce and carry `capacityTonnes`.
  kind            LocationKind   @default(FIELD)
  /// Storage capacity in metric tonnes (BIN/STORAGE only). Null for a
  /// FIELD. Used to compute bin fill % against the sum of stored lots.
  capacityTonnes  Decimal?       @db.Decimal(14, 2)
  ownerUserId     String?
  /// Original uploaded spatial file (shapefile .zip / .kml / .geojson),
  /// stored via the existing FileRecord pipeline (domain "spatial").
  spatialFileId   String?
  spatialFormat   String? // "shapefile" | "kml" | "geojson"
  /// [west, south, east, north] in WGS84, for initial map fit.
  boundsJson      Json?
  createdByUserId String?
  /// "Try it with sample data": rows seeded into the tenant's own
  /// workspace, tagged so a one-tap "Clear sample data" can remove
  /// exactly them (and nothing else). Plain boolean, default-false —
  /// additive + RLS-safe; no index (low-selectivity flag).
  isSampleData    Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  owner         User?          @relation("LocationOwner", fields: [ownerUserId], references: [id])
  createdBy     User?          @relation("LocationCreator", fields: [createdByUserId], references: [id])
  spatialFile   FileRecord?    @relation("LocationSpatialFile", fields: [spatialFileId], references: [id])
  parcels       Parcel[]
  inventoryLots InventoryLot[]
  logLocations  LogLocation[]
  cropPlans     CropPlan[]
  plantings     Planting[]
  weatherObservations WeatherObservation[]
  dataStreams         DataStream[]
  agroSignals         AgroSignal[]
  yieldRecords        YieldRecord[]

  @@unique([id, tenantId])
  @@unique([tenantId, key])
  @@index([tenantId, name])
  @@index([tenantId, status])
  @@index([tenantId, kind])
}

/// One polygon imported from the spatial file. geometry is PostGIS
/// (MultiPolygon, 4326); areaHa is denormalized via ST_Area at import
/// (never client-written). propertiesJson preserves the source
/// feature's attributes.
model Parcel {
  id              String                                       @id @default(cuid())
  tenantId        String
  locationId      String
  key             String?
  name            String
  cropType        String?
  /// Bulgarian КАИС cadastral identifier `EKATTE.masiv.parcel`
  /// (e.g. `68134.8360.729`), parsed from the source attributes at import.
  cadastralId     String?
  /// 5-digit EKATTE settlement prefix of `cadastralId` (leading zeros
  /// significant), indexed for per-settlement cadastre lookups.
  ekatte          String?
  geometry        Unsupported("geometry(MultiPolygon, 4326)")?
  areaHa          Decimal?                                     @db.Decimal(12, 4)
  propertiesJson  Json?
  /// Human-readable soil label (USDA texture class, e.g. "Silty clay
  /// loam", or a WRB group) derived from the modelled soil profile.
  /// A MODELLED ESTIMATE from open data (SoilGrids), never a lab result.
  soilType        String?
  /// Structured soil profile — the SoilGrids-derived reading + provenance:
  /// { wrbClass?, textureClass, sandPct, siltPct, clayPct, phH2o, socGkg,
  ///   bulkDensity, depth, uncertainty?, provider, fetchedAt }.
  /// Null until the async soil-fetch job populates it ("soil pending").
  soilJson        Json?
  /// "Try it with sample data" tag — see Location.isSampleData.
  isSampleData    Boolean                                      @default(false)
  createdAt       DateTime                                     @default(now())
  updatedAt       DateTime                                     @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  location       Location          @relation(fields: [locationId, tenantId], references: [id, tenantId], onDelete: Cascade)
  operationLines OperationParcel[]
  plantings      Planting[]
  cropPlans      CropPlan[]

  @@unique([id, tenantId])
  @@index([tenantId, locationId])
  // perf-scale: the parcel-list read filters tenantId + locationId +
  // deletedAt IS NULL — folding deletedAt into the index lets a 5k-parcel
  // field scan only live rows. (The GiST index on `geometry` is separate.)
  @@index([tenantId, locationId, deletedAt])
  // Per-settlement cadastre lookups (КАИС): find every parcel in an EKATTE.
  @@index([tenantId, ekatte])
}

/// GLOBAL soil-sample cache (NO tenantId — a shared catalog of open,
/// non-tenant soil data, like `Unit`). Keyed by a rounded lat/lon grid
/// cell (~100 m at Bulgaria's latitude) so a parcel centroid resolves to
/// the same cell as its neighbours and we NEVER refetch a nearby point —
/// this cache is the primary way we respect the SoilGrids fair-use budget.
/// Soil is effectively static, so the TTL is unbounded (no expiry).
///
/// `latE3`/`lonE3` are the WGS84 lat/lon rounded to 3 decimals then
/// stored as integer milli-degrees (e.g. 42.6975 → 42698), which gives an
/// exact, index-friendly equality key without Decimal-precision snags.
model SoilSample {
  id        String   @id @default(cuid())
  /// Rounded latitude  × 1000 (integer milli-degrees, 3-decimal grid).
  latE3     Int
  /// Rounded longitude × 1000 (integer milli-degrees, 3-decimal grid).
  lonE3     Int
  /// Provider key — "soilgrids" today (matches SOIL_PROVIDER).
  provider  String
  /// Structured soil profile — same shape as `Parcel.soilJson`.
  dataJson  Json
  /// When the provider response was captured (provenance / re-fetch audit).
  fetchedAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([latE3, lonE3])
}

/// GLOBAL cache of a downloaded КАИС OpenData settlement archive (NO tenantId —
/// public open data, identical for every tenant, exactly like `SoilSample`).
/// Keyed by the 5-digit ЕКАТТЕ. Lets repeat cadastre imports within the
/// freshness window reuse the already-fetched "поземлени имоти" (land-parcels)
/// ZIP instead of re-hitting КАИС OpenData. The ZIP bytes live in the storage
/// abstraction (domain 'spatial') at `storageKey`.
///
/// PRIVACY: only the land-parcels archive (geometry + cadastral identifier +
/// land-use) is ever fetched or cached here. The КАИС ownership registers
/// (собственост*.zip — personal data) are NEVER downloaded or persisted.
model CadastreArchive {
  id         String   @id @default(cuid())
  /// 5-digit ЕКАТТЕ settlement code (leading zeros significant).
  ekatte     String   @unique
  /// КАИС source freshness stamp (the tree entry's ModifiedUtc) — provenance +
  /// the freshness check that decides reuse vs re-fetch.
  sourceDate DateTime
  /// Storage object key (domain 'spatial') of the cached land-parcels ZIP. A
  /// plain key, NOT a tenant-scoped `FileRecord` FK — the cache is global.
  storageKey String
  /// Bytes of the cached ZIP (provenance / accounting).
  sizeBytes  Int
  /// КАИС tree Path the archive resolved from (debug / provenance).
  sourcePath String?
  fetchedAt  DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// LEGAL-ENTITY ("юридическо лице") ownership of a cadastral parcel, extracted
/// from the КАИС OpenData „собственост ПИ" register. GLOBAL — no tenantId / no
/// RLS, like CadastreArchive / SoilSample: ownership is public open data shared
/// across tenants, keyed by cadastral identifier, so parcels hydrate their
/// owner at read time by joining on `cadastralId`.
///
/// PHYSICAL persons are NEVER stored here: КАИС masks them at source (asterisk
/// «име на лицето» + hex-encrypted ЕГН) and `lib/cadastre/ownership.ts` drops
/// every masked/person row before persist. Only readable legal entities with a
/// numeric ЕИК land in this table (locked by tests/unit/cadastre-ownership.test.ts).
model CadastreOwner {
  id          String    @id @default(cuid())
  /// Cadastral identifier of the owned parcel (join key to Parcel.cadastralId).
  cadastralId String
  /// 5-digit ЕКАТТЕ settlement code the register was sourced from.
  ekatte      String
  /// ЕИК / БУЛСТАТ of the legal entity (numeric, leading zeros preserved).
  eik         String
  /// Readable legal-entity name (Община …, … ЕООД, държава).
  name        String
  /// «вид на правото» — ownership right type ("" when absent; part of the key).
  rightType   String    @default("")
  /// «вид на лицето» — subject kind (Община, ЕООД, държава …), or null.
  subjectKind String?
  /// КАИС register freshness stamp (source ModifiedUtc) — provenance.
  sourceDate  DateTime?
  fetchedAt   DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([cadastralId, eik, rightType])
  @@index([cadastralId])
  @@index([ekatte])
}

/// The per-parcel prescription line — the heart of the feature. The
/// spray "job" is a FIELD_OPERATION Task (assignment, status,
/// comments, notifications all reused); each parcel in the job gets
/// one OperationParcel with its product + dose. The job auto-resolves
/// when every line is DONE/SKIPPED.
model OperationParcel {
  id                String                @id @default(cuid())
  tenantId          String
  taskId            String // the FIELD_OPERATION Task (simple FK; Task has no [id,tenantId] barrier)
  parcelId          String
  productItemId     String
  doseValue         Decimal               @db.Decimal(14, 4)
  doseUnitId        String
  // Water-carrier rate for the spray tank (per-decare), set only on the
  // treatment line. Per-parcel total water = waterRateValue × parcel dca.
  waterRateValue    Decimal?              @db.Decimal(14, 4)
  waterRateUnitId   String?
  targetNote        String?
  status            ParcelOperationStatus @default(PENDING)
  completedAt       DateTime?
  completedByUserId String?
  // Optimistic-lock counter — bumped on every mutation. A queued offline mark
  // captures the version it saw and sends it back as `If-Match` on replay; the
  // server rejects the write with 409 STALE_DATA if the row moved on
  // meanwhile (a supervisor edited the job), so a hours-late replay can't
  // silently clobber newer server state. Idempotency stops duplication; this
  // stops staleness.
  version           Int                   @default(0)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  task        Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  parcel      Parcel     @relation(fields: [parcelId, tenantId], references: [id, tenantId])
  product       Item       @relation(fields: [productItemId, tenantId], references: [id, tenantId])
  doseUnit      Unit       @relation("OperationParcelDoseUnit", fields: [doseUnitId], references: [id])
  waterRateUnit Unit?      @relation("OperationParcelWaterUnit", fields: [waterRateUnitId], references: [id])
  completedBy   User?      @relation("OperationParcelCompleter", fields: [completedByUserId], references: [id])
  logEntries    LogEntry[]

  // A field operation may apply MORE THAN ONE product to a parcel — a
  // spray job records a soil-nurturing fertilizer line AND a treatment
  // product line per parcel. The uniqueness is therefore per product,
  // not one line per parcel.
  @@unique([taskId, parcelId, productItemId])
  @@index([tenantId, taskId])
  @@index([tenantId, parcelId])
  @@index([tenantId, status])
  @@index([tenantId, waterRateUnitId])
}

/// WP-2 — per-tenant module gating (one row per tenant). enabledModules
/// is a Postgres enum array; absence of a row means "all modules
/// enabled" (resolved in src/lib/modules.ts). Tenant-scoped → RLS trio.
model TenantModuleSettings {
  id             String      @id @default(cuid())
  tenantId       String      @unique
  enabledModules ModuleKey[]
  /// Per-tenant Meteobot station embed/link URL (#14). Null → the Climate
  /// page falls back to the built-in Open-Meteo weather layer. A placeholder
  /// seam for the real Meteobot API later.
  meteobotStationUrl String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

/// One-per-tenant farm identity block for the Bulgarian БАБХ
/// "ДНЕВНИК за проведените растителнозащитни мероприятия и торене"
/// (Прил. 1 към заповед РД 11-3194/31.12.2021). Every field is optional
/// — the paper form tolerates blanks (rendered as dotted lines). 1:1 with
/// Tenant (`tenantId @unique`, singleton config like TenantModuleSettings)
/// → RLS trio in the migration, no soft-delete.
///
/// egn (ЕГН — personal ID) and eik (ЕИК — company ID) are SENSITIVE and
/// registered in the Epic B encrypted-fields manifest
/// (src/lib/security/encrypted-fields.ts) — stored as ciphertext, never
/// searched (the row is fetched by tenantId only).
model FarmProfile {
  id                         String   @id @default(cuid())
  tenantId                   String   @unique
  /// Име/фирма на земеделския производител.
  producerName               String?
  /// ЕГН — encrypted at rest (Epic B manifest).
  egn                        String?
  /// ЕИК — encrypted at rest (Epic B manifest).
  eik                        String?
  address                    String?
  /// Община.
  municipality               String?
  /// Населено място.
  settlement                 String?
  /// ОД "Земеделие" гр.
  agricultureDirectorateCity String?
  /// Място на регистриране.
  registrationPlace          String?
  /// ЕКАТТЕ код (5 знака) — kept as free String; the form tolerates blanks.
  registrationEkatte         String?
  /// ОДБХ гр.
  odbhCity                   String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}
