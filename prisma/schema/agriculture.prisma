// ═══════════════════════════════════════════════════════════════════
//  AGRICULTURE DOMAIN — Feature 1: spray-prescription map module
// ═══════════════════════════════════════════════════════════════════
//
//  GAP-09 multi-file schema: new domain file. Generator + datasource
//  remain in base.prisma.
//
//  House conventions mirrored from compliance.prisma:
//    • cuid ids, createdAt/updatedAt, soft-delete trio
//      (deletedAt / deletedByUserId / retentionUntil).
//    • Cross-tenant row barrier `@@unique([id, tenantId])` on tenant
//      parents I own (Location, Parcel, Item), with composite child
//      FKs `[xId, tenantId] → [id, tenantId]`. Task lacks that barrier
//      (only `@@unique([tenantId, key])`), so OperationParcel→Task is
//      a simple FK; tenant isolation there is enforced by RLS + the
//      OperationParcel.tenantId column.
//    • Every tenant-scoped table (tenantId column) gets the canonical
//      RLS trio (tenant_isolation + tenant_isolation_insert +
//      superuser_bypass + FORCE) in the migration. The rls-coverage
//      guardrail derives the tenant-scoped set from the DMMF and will
//      fail CI otherwise. `Unit` has NO tenantId (global catalog) →
//      no RLS, intentionally.
//
//  Geometry: PostGIS via `Unsupported(...)`. Prisma never reads/writes
//  it through the client — all spatial SQL lives in `src/lib/db/geo.ts`.
//  The `postgis` extension is created by the migration (we do not use
//  the datasource `extensions` preview feature, so the CREATE EXTENSION
//  is hand-authored at the top of the migration).
//
//  Back-relations added elsewhere (Prisma needs both sides):
//    • auth.prisma   Tenant: locations / parcels / items / operationParcels
//    • auth.prisma   User:   LocationOwner / LocationCreator /
//                            ItemCreator / OperationParcelCompleter
//    • compliance.prisma Task:       operationParcels OperationParcel[]
//    • compliance.prisma FileRecord: locationSpatialFiles Location[]
//                                    @relation("LocationSpatialFile")
// ═══════════════════════════════════════════════════════════════════

/// Global unit-of-measure catalog (no tenantId → not tenant-scoped,
/// no RLS). Seeded by scripts/import-units.ts. A spray dose is a RATE
/// unit (e.g. "L/ha"); product default units are VOLUME/WEIGHT/COUNT.
model Unit {
  id        String          @id @default(cuid())
  key       String          @unique // "l-per-ha", "kg", "l"
  name      String
  symbol    String
  measure   QuantityMeasure
  createdAt DateTime        @default(now())

  itemsDefault      Item[]             @relation("ItemDefaultUnit")
  doseLines         OperationParcel[]  @relation("OperationParcelDoseUnit")
  waterLines        OperationParcel[]  @relation("OperationParcelWaterUnit")
  invLots           InventoryLot[]     @relation("InventoryLotUnit")
  stockTransactions StockTransaction[] @relation("StockTransactionUnit")
  logQuantities     LogQuantity[]      @relation("LogQuantityUnit")
}

/// Tenant-scoped input-product catalog (the structured spray product).
/// Feature 1 exercises PESTICIDE/FERTILIZER; other categories are the
/// seed of the full inventory module. attributesJson carries
/// regulatory metadata (active ingredient, REI/PHI) until promoted.
model Item {
  id              String       @id @default(cuid())
  tenantId        String
  name            String
  category        ItemCategory
  sku             String?
  defaultUnitId   String
  /// Low-stock alert threshold in defaultUnit (InvenTree pattern). The
  /// lots list surfaces "low stock" when SUM(lot.quantityOnHand) drops
  /// below it; null disables the check.
  reorderLevel    Decimal?     @db.Decimal(14, 3)
  attributesJson  Json?
  createdByUserId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  defaultUnit    Unit              @relation("ItemDefaultUnit", fields: [defaultUnitId], references: [id])
  createdBy      User?             @relation("ItemCreator", fields: [createdByUserId], references: [id])
  operationLines OperationParcel[]
  lots           InventoryLot[]

  @@unique([id, tenantId])
  @@index([tenantId, category])
  @@index([tenantId, name])
}

/// The farm/field block a farmer uploads a spatial file into. Shaped
/// after the Asset model (key, name, owner, status, soft-delete).
/// Holds the original uploaded FileRecord + a cached bounding box for
/// map fit; the parcels themselves are child rows.
model Location {
  id              String         @id @default(cuid())
  tenantId        String
  key             String?
  name            String
  description     String?
  status          LocationStatus @default(ACTIVE)
  /// Enterprise-grain: physical kind. FIELD (default) is a growing area;
  /// BIN/STORAGE hold harvested produce and carry `capacityTonnes`.
  kind            LocationKind   @default(FIELD)
  /// Storage capacity in metric tonnes (BIN/STORAGE only). Null for a
  /// FIELD. Used to compute bin fill % against the sum of stored lots.
  capacityTonnes  Decimal?       @db.Decimal(14, 2)
  ownerUserId     String?
  /// Original uploaded spatial file (shapefile .zip / .kml / .geojson),
  /// stored via the existing FileRecord pipeline (domain "spatial").
  spatialFileId   String?
  spatialFormat   String? // "shapefile" | "kml" | "geojson"
  /// [west, south, east, north] in WGS84, for initial map fit.
  boundsJson      Json?
  createdByUserId String?
  /// "Try it with sample data": rows seeded into the tenant's own
  /// workspace, tagged so a one-tap "Clear sample data" can remove
  /// exactly them (and nothing else). Plain boolean, default-false —
  /// additive + RLS-safe; no index (low-selectivity flag).
  isSampleData    Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  owner         User?          @relation("LocationOwner", fields: [ownerUserId], references: [id])
  createdBy     User?          @relation("LocationCreator", fields: [createdByUserId], references: [id])
  spatialFile   FileRecord?    @relation("LocationSpatialFile", fields: [spatialFileId], references: [id])
  parcels       Parcel[]
  inventoryLots InventoryLot[]
  logLocations  LogLocation[]
  cropPlans     CropPlan[]
  plantings     Planting[]
  weatherObservations WeatherObservation[]
  dataStreams         DataStream[]
  agroSignals         AgroSignal[]
  yieldRecords        YieldRecord[]

  @@unique([id, tenantId])
  @@unique([tenantId, key])
  @@index([tenantId, name])
  @@index([tenantId, status])
  @@index([tenantId, kind])
}

/// One polygon imported from the spatial file. geometry is PostGIS
/// (MultiPolygon, 4326); areaHa is denormalized via ST_Area at import
/// (never client-written). propertiesJson preserves the source
/// feature's attributes.
model Parcel {
  id              String                                       @id @default(cuid())
  tenantId        String
  locationId      String
  key             String?
  name            String
  cropType        String?
  geometry        Unsupported("geometry(MultiPolygon, 4326)")?
  areaHa          Decimal?                                     @db.Decimal(12, 4)
  propertiesJson  Json?
  /// "Try it with sample data" tag — see Location.isSampleData.
  isSampleData    Boolean                                      @default(false)
  createdAt       DateTime                                     @default(now())
  updatedAt       DateTime                                     @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  location       Location          @relation(fields: [locationId, tenantId], references: [id, tenantId], onDelete: Cascade)
  operationLines OperationParcel[]
  plantings      Planting[]

  @@unique([id, tenantId])
  @@index([tenantId, locationId])
  // perf-scale: the parcel-list read filters tenantId + locationId +
  // deletedAt IS NULL — folding deletedAt into the index lets a 5k-parcel
  // field scan only live rows. (The GiST index on `geometry` is separate.)
  @@index([tenantId, locationId, deletedAt])
}

/// The per-parcel prescription line — the heart of the feature. The
/// spray "job" is a FIELD_OPERATION Task (assignment, status,
/// comments, notifications all reused); each parcel in the job gets
/// one OperationParcel with its product + dose. The job auto-resolves
/// when every line is DONE/SKIPPED.
model OperationParcel {
  id                String                @id @default(cuid())
  tenantId          String
  taskId            String // the FIELD_OPERATION Task (simple FK; Task has no [id,tenantId] barrier)
  parcelId          String
  productItemId     String
  doseValue         Decimal               @db.Decimal(14, 4)
  doseUnitId        String
  // Water-carrier rate for the spray tank (per-decare), set only on the
  // treatment line. Per-parcel total water = waterRateValue × parcel dca.
  waterRateValue    Decimal?              @db.Decimal(14, 4)
  waterRateUnitId   String?
  targetNote        String?
  status            ParcelOperationStatus @default(PENDING)
  completedAt       DateTime?
  completedByUserId String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  task        Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  parcel      Parcel     @relation(fields: [parcelId, tenantId], references: [id, tenantId])
  product       Item       @relation(fields: [productItemId, tenantId], references: [id, tenantId])
  doseUnit      Unit       @relation("OperationParcelDoseUnit", fields: [doseUnitId], references: [id])
  waterRateUnit Unit?      @relation("OperationParcelWaterUnit", fields: [waterRateUnitId], references: [id])
  completedBy   User?      @relation("OperationParcelCompleter", fields: [completedByUserId], references: [id])
  logEntries    LogEntry[]

  // A field operation may apply MORE THAN ONE product to a parcel — a
  // spray job records a soil-nurturing fertilizer line AND a treatment
  // product line per parcel. The uniqueness is therefore per product,
  // not one line per parcel.
  @@unique([taskId, parcelId, productItemId])
  @@index([tenantId, taskId])
  @@index([tenantId, parcelId])
  @@index([tenantId, status])
  @@index([tenantId, waterRateUnitId])
}

/// WP-2 — per-tenant module gating (one row per tenant). enabledModules
/// is a Postgres enum array; absence of a row means "all modules
/// enabled" (resolved in src/lib/modules.ts). Tenant-scoped → RLS trio.
model TenantModuleSettings {
  id             String      @id @default(cuid())
  tenantId       String      @unique
  enabledModules ModuleKey[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}
