/// A supplier / advertiser that runs promotions ("Offers" / Промоции) — #12.
///
/// GLOBAL catalogue (NO tenantId, like `Promotion` / `Unit` / `AgriEvent`) →
/// not tenant-scoped, no RLS: every tenant sees the same suppliers. Curated by
/// platform support, never by tenants.
///
/// Replaces the free-text `Promotion.company` string. A supplier runs repeat
/// campaigns, so the identity has to outlive any single promotion — with a
/// bare string, "Syngenta" and "Syngenta " were two unrelated advertisers and
/// the contact address had to be re-typed per campaign.
///
/// **Two privacy classes in one row.** `name` / `eik` / `websiteUrl` /
/// `logoUrl` are PUBLIC — the name renders in every tenant's offers feed, and
/// the ЕИК is commercial-register data. The contact fields and support notes
/// are INTERNAL personal data of a named individual and are encrypted at rest
/// (see `ENCRYPTED_FIELDS`). They are deliberately NOT exposed by
/// `listActivePromotions`.
model Company {
  id           String   @id @default(cuid())
  /// Public display name — rendered cross-tenant.
  name         String
  /// Normalised `name` (lowercased, whitespace-collapsed). The dedup key that
  /// stops one supplier forking into several through typing variance.
  nameKey      String   @unique
  /// Bulgarian company registration number (ЕИК). Public register data for a
  /// legal entity, so unlike `Lease.lessorEik` (often a natural person) it is
  /// not encrypted.
  eik          String?
  websiteUrl   String?
  logoUrl      String?
  /// ── Internal, encrypted at rest ──
  contactName  String?
  contactEmail String?
  contactPhone String?
  /// Support's free-text notes on the relationship. Encrypted + sanitised.
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  promotions Promotion[]

  @@index([name])
}

/// Company promotions ("Offers" / Промоции) — #12.
///
/// `Promotion` is a GLOBAL catalogue (NO tenantId, like `Unit` / `AgriEvent`)
/// → not tenant-scoped, no RLS: every tenant reads the same shared feed of
/// supplier promotions. Curated by platform support; lead-gen only (no billing).
/// `category` is a curated String from culture/fertilizer/seeds/products/service.
///
/// **Visibility is two gates, not one.** `publishedAt` is the editorial gate
/// (null = draft, invisible however the dates read) and `validFrom`/`validTo`
/// are the campaign window. Both must pass. Before `publishedAt` existed an
/// insert WAS a publish — a half-finished row with blank dates went live in
/// every tenant's feed immediately, which is the likeliest way support ships an
/// unfinished ad.
model Promotion {
  id          String    @id @default(cuid())
  companyId   String
  title       String
  body        String?
  mediaUrl    String?
  /// Curated category: "culture" | "fertilizer" | "seeds" | "products" | "service".
  category    String    @default("service")
  ctaUrl      String?
  /// Editorial gate — null means draft. Set when support publishes.
  publishedAt DateTime?
  validFrom   DateTime?
  validTo     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company         @relation(fields: [companyId], references: [id])
  leads   PromotionLead[]

  @@index([createdAt])
  @@index([companyId])
  /// Backs the active-window predicate in `listActivePromotions`, which was
  /// scanning unindexed before.
  @@index([validTo])
}

/// A lead captured when a user clicks "Ask for offer" on a promotion.
///
/// Mirrors `ExchangeInquiry`: `inquirerTenantId` is a PLAIN FK to Tenant.id
/// (NOT a tenantId RLS column) — the row is not tenant-scoped, so no RLS. The
/// @@unique dedup caps a tenant to one lead per promotion. Lead-gen only:
/// storing the row + a confirmation notification is the whole flow (no
/// provider portal / payment yet).
model PromotionLead {
  id               String   @id @default(cuid())
  promotionId      String
  /// Inquiring tenant — plain FK to Tenant.id (NOT a tenantId RLS column).
  inquirerTenantId String
  inquirerUserId   String
  /// ENCRYPTED at rest (Epic B manifest). Free text the farmer wrote — it
  /// routinely names the farm, the field and what they are short of, and it
  /// is destined for a third-party supplier. Encrypted under the INQUIRING
  /// tenant's DEK (the write runs in that tenant's context), NOT the global
  /// KEK: the message belongs to the farmer, so per-tenant key isolation is
  /// the correct posture. A reader outside that tenant (the future digest
  /// job) must therefore resolve each lead's tenant context to decrypt.
  ///
  /// NAMED `requestMessage`, NOT `message`, and that is load-bearing. The Epic
  /// B middleware's fan-out encrypt path (`encryptDataNodeAllModels`, used when
  /// a nested write's target model is structurally unknown) matches on a FLAT
  /// set of field names across the whole manifest — it cannot tell which model
  /// a key belongs to. `message` is shared by `Notification`, `ExchangeInquiry`
  /// and `InsuranceLead`, so putting THAT name in the manifest silently
  /// encrypted their columns too. (Caught by the automation suite: a
  /// `Notification.message` came back as `v1:…`.) A model-unique name makes the
  /// collision impossible. `@map("message")` keeps the physical column, so this
  /// is a Prisma-level rename with no data migration.
  requestMessage   String   @map("message")
  /// Optional parcel/context the request is about (free-form id, no FK).
  contextParcelId  String?
  /// When the farmer ticked the consent box. NOT NULL by design: a lead
  /// without recorded consent is one we may not lawfully forward to a
  /// supplier, so the column is the enforcement point, not a flag. The
  /// usecase rejects a request whose consent is absent, so this is always
  /// set at creation.
  consentedAt      DateTime
  /// Soft-delete + retention. Contact PII does not live forever: see the
  /// retention note in the implementation doc for the window and the sweep.
  deletedAt        DateTime?
  /// Curated status: "PENDING" | "CONTACTED" | "CLOSED".
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([promotionId, inquirerTenantId])
  @@index([promotionId])
  @@index([inquirerTenantId])
  /// Retention sweep: find undeleted leads past the window without scanning.
  @@index([deletedAt, createdAt])
}
