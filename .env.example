# NextAuth
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
AUTH_SECRET="your-secret-key-here-must-be-min-16-chars"
JWT_SECRET="your-secret-key-here-must-be-min-16-chars"

# Database (PgBouncer connection pooling)
# Runtime queries go through PgBouncer on port 5433 (pooled, transaction mode).
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/inflect_compliance?schema=public&pgbouncer=true"
# Direct Postgres connection on port 5434 for Prisma migrations/introspection.
DIRECT_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5434/inflect_compliance?schema=public"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
MICROSOFT_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret"
MICROSOFT_TENANT_ID="common"

# File Storage
UPLOAD_DIR="./uploads"

# API & Security
CORS_ALLOWED_ORIGINS="http://localhost:3000,https://production-app.com"

# Rate Limiting
# RATE_LIMIT_ENABLED="1"
# RATE_LIMIT_MODE="memory" # use 'upstash' in prod
# UPSTASH_REDIS_REST_URL="https://your-upstash-url"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Data Encryption — REQUIRED in production (GAP-03 enforced).
# Production startup runs three checks in `src/env.ts` and
# `src/instrumentation.ts`: presence + length + functional sentinel
# (encrypt → decrypt round-trip). Boot exits 1 if any fail.
#
# Local dev: leave UNSET to use the in-source dev fallback (logged
# as a WARN on every server start). Set this if you want to
# round-trip encrypted columns from a real prod backup locally.
#
# Generate a real key with:  openssl rand -base64 48
# DATA_ENCRYPTION_KEY="your-encryption-key-min-32-chars"

# Redis (caching, jobs, async coordination)
# docker compose up -d redis  →  available at localhost:6379
REDIS_URL="redis://127.0.0.1:6379"

# Parcel map basemap (MapTiler).
# Get a free key at https://cloud.maptiler.com/account/keys/ and
# restrict it by HTTP referrer (it's fetched in the browser, so it is
# necessarily public — referrer-restrict it, don't treat it as a secret).
# Unset → the map falls back to the bare MapLibre demo style (no imagery).
# NEXT_PUBLIC_MAPTILER_KEY="your-maptiler-key"
# Style id: hybrid (satellite + labels, default) | satellite | streets-v2 | outdoor-v2 | basic-v2
# NEXT_PUBLIC_MAP_BASEMAP_STYLE="hybrid"

# NDVI overlay (Google Earth Engine). Both REQUIRED to enable NDVI;
# unset → the map's NDVI toggle shows a muted "not configured" hint.
# GEE_PROJECT_ID = the Earth-Engine-registered Google Cloud project id.
# GEE_SERVICE_ACCOUNT_KEY = the FULL service-account JSON key, as a string
# (single line). Runtime secret — never commit a real key; on a deploy it
# lives in the server env only. Commercial use needs a paid Earth Engine
# subscription on the project.
# GEE_PROJECT_ID="your-ee-cloud-project"
# GEE_SERVICE_ACCOUNT_KEY='{"type":"service_account", ...}'
