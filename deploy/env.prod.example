# deploy/env.prod.example — production env KEYS (no values).
#
# This is the deploy-side companion to src/env.ts. Copy it to the VM as
# /opt/agrent/.env, fill every value, and keep it OFF git. A unit test
# (tests/guardrails/deploy-env-parity.test.ts) asserts that every variable
# src/env.ts REQUIRES in production appears here — so a newly-required var can't
# ship without this file learning about it.
#
# NEVER commit real values. NEVER echo /opt/agrent/.env in logs or CI.

# ── Core: database (PgBouncer at runtime, direct for migrations) ──
DATABASE_URL=
DIRECT_DATABASE_URL=

# ── Redis (REQUIRED + AUTHENTICATED in prod — redis://:PASSWORD@HOST:6379) ──
REDIS_URL=

# ── NextAuth / session ──
NEXTAUTH_URL=
AUTH_URL=
AUTH_SECRET=
JWT_SECRET=

# ── OAuth providers (required by src/env.ts even when unused — set a value) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Field encryption master KEK (REQUIRED in prod; openssl rand -base64 48) ──
DATA_ENCRYPTION_KEY=

# ── File storage (local disk on the single-VM deploy) ──
UPLOAD_DIR=

# ── Compose interpolation vars (consumed by docker-compose.vm.yml, not env.ts) ──
# Postgres + Redis credentials the container stack builds its URLs from.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
REDIS_PASSWORD=
# Map basemap key baked into the client bundle at build time.
NEXT_PUBLIC_MAPTILER_KEY=
