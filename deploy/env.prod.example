# deploy/env.prod.example — production env KEYS (no values).
#
# This is the deploy-side companion to src/env.ts. Copy it to the VM as
# /opt/agrent/.env, fill every value, and keep it OFF git. A unit test
# (tests/guardrails/deploy-env-parity.test.ts) asserts that every variable
# src/env.ts REQUIRES in production appears here — so a newly-required var can't
# ship without this file learning about it.
#
# NEVER commit real values. NEVER echo /opt/agrent/.env in logs or CI.

# ── Core: database (PgBouncer at runtime, direct for migrations) ──
DATABASE_URL=
DIRECT_DATABASE_URL=

# ── Redis (REQUIRED + AUTHENTICATED in prod — redis://:PASSWORD@HOST:6379) ──
REDIS_URL=

# ── NextAuth / session ──
NEXTAUTH_URL=
AUTH_URL=
AUTH_SECRET=
JWT_SECRET=

# ── OAuth providers (required by src/env.ts even when unused — set a value) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Field encryption master KEK (REQUIRED in prod; openssl rand -base64 48) ──
DATA_ENCRYPTION_KEY=

# ── File storage (local disk on the single-VM deploy) ──
UPLOAD_DIR=

# ── Compose interpolation vars (consumed by docker-compose.vm.yml, not env.ts) ──
# Postgres + Redis credentials the container stack builds its URLs from.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
REDIS_PASSWORD=
# Map basemap key baked into the client bundle at build time.
NEXT_PUBLIC_MAPTILER_KEY=
# Browser Sentry DSN — absent ⇒ the client error SDK stays a no-op.
# Baked into the client bundle at build time. Optional (self-hosted stays clean).
NEXT_PUBLIC_SENTRY_DSN=
# Optional release tag so field crashes map to a deploy.
NEXT_PUBLIC_SENTRY_RELEASE=

# ── Bulgarian cadastre (КККР / АГКК) WMS overlay (ALL optional) ──
# The location-map cadastre overlay is HIDDEN unless one of these is set — the
# free INSPIRE view WMS for КККР parcels could not be located by probing, so
# there is no baked-in default. Server-only (never NEXT_PUBLIC): a paid №8002
# licence is IP-bound to the VM, so tiles are fetched server-side via the
# same-origin proxy. Enabling the paid layer is an operator cost decision —
# see docs/implementation-notes/2026-07-13-cadastre-wms-overlay.md for the
# commercial terms (80 лв/мес or 800 лв/год per layer per IP-bound access
# point, Наредба РД-02-20-4/2016 + Тарифа 14, via КАИС).
# CADASTRE_WMS_URL=          # WMS GetMap base OR an ArcGIS …/MapServer (auto-detected).
#                            # Free АГКК parcels source (ArcGIS export, reprojected):
#                            # https://arcgis.cadastre.bg/arcgisnopki/rest/services/ExternalKais/ParcelsCache/MapServer
# CADASTRE_WMS_LAYERS=       # WMS LAYERS (default CP.CadastralParcel)
# CADASTRE_WMS_PREMIUM_URL=  # paid №8002 GetMap base (wins when set)
#
# VECTOR parcels overlay — the FREE default that actually renders (preferred over
# the raster WMS above when set). ArcGIS FeatureServer-style layer; its /query is
# fetched server-side + reprojected to 4326 GeoJSON via the same-origin
# /cadastre/parcels proxy. The client sees only a `configured` boolean.
# CADASTRE_PARCELS_URL=      # https://spp.api.bg/arcgis/rest/services/Public/CadBaseMap/MapServer/2
# КАИС cadastre OpenData import (feat/cadastre-opendata-import). Optional,
# server-only — when unset the "import from the cadastre" tab is hidden.
# CADASTRE_OPENDATA_INDEX_URL=   # https://kais.cadastre.bg OpenData base

# ── Market-price trends backbone (feat/trends-data-backbone) ── ALL optional.
# The market-prices-pull job caches EC AGRI-food + Alpha Vantage + own-listings
# price series. EC works with no config (public API). Set ALPHA_VANTAGE_API_KEY
# to enable the global reference feed (free key; 25 req/day) — unset ⇒ skipped.
# EC_AGRIFOOD_BASE_URL=          # override EC AGRI-food API base (default https://www.ec.europa.eu/agrifood/api)
# ALPHA_VANTAGE_API_KEY=         # Alpha Vantage free key (enables WHEAT/CORN global reference series)
#
# The market-news-pull job aggregates free agri RSS/Atom feeds into the Trends →
# News tab. Curated defaults live in src/lib/news/feeds.ts; override the whole
# list here without a redeploy (JSON array of {slug,url,category}, category ∈
# market|policy|general). Unset/malformed ⇒ defaults. Fail-soft per feed.
# MARKET_NEWS_FEEDS=             # e.g. [{"slug":"agri-bg","url":"https://agri.bg/rss","category":"general"}]
