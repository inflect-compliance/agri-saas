#
# Caddy reverse proxy for agrent.
# The site domain (e.g. 35-187-80-26.sslip.io) is substituted by the deploy
# script once the VM's external IP is known (pattern: <ip-with-dashes>.sslip.io).
# Let's Encrypt issues a cert automatically on first request.
#

{
    # Use the production LE endpoint by default (default behaviour).
    # Set ACME_EMAIL in the env if you want certificate expiry mail.
    email {$ACME_EMAIL:admin@agrent.bg}
}

35-187-80-26.sslip.io {
    encode gzip zstd

    # Client-body limit roughly matches FILE_MAX_SIZE_BYTES above.
    request_body {
        max_size 110MB
    }

    # Security headers.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        -Server
    }

    reverse_proxy app:3000 {
        # Next.js sits behind the proxy — forward the original host so
        # NextAuth + server-side redirects resolve to the public URL.
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}
