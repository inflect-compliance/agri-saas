# ───────────────────────────────────────────────────────────────
# DEPRECATED — plaintext production env file.
#
# As of Epic OI-1 (2026-04-27), production secrets live in AWS
# Secrets Manager. This file remains as a TEMPLATE for the small
# set of NON-secret values the runtime needs; secrets are resolved
# at deploy time by:
#
#   scripts/bootstrap-env-from-secrets.sh
#
# That script writes `.env.runtime` (mode 0600) with both the
# values from this file AND the resolved secrets. The compose
# stack's env_file directive points at .env.runtime.
#
# DO NOT put secrets in this file. The `_PASSWORD`, `_SECRET`, and
# `DATA_ENCRYPTION_KEY` lines that used to live here are gone —
# their values now live exclusively in AWS Secrets Manager.
#
# See docs/infrastructure.md → "Secret management" for the full
# model and the rotation runbook.
# ───────────────────────────────────────────────────────────────

NODE_ENV=production

# ── Connection targets (NOT secrets — discoverable from terraform output) ──
# Fill these from `terraform -chdir=infra/terraform output` after
# applying the production stack.
DATABASE_HOST=REPLACE_ME_RDS_ENDPOINT_HOSTNAME
REDIS_HOST=REPLACE_ME_ELASTICACHE_PRIMARY_ENDPOINT
S3_BUCKET=REPLACE_ME_S3_BUCKET_ID
S3_REGION=us-east-1

# ── App routing ──
APP_HOSTNAME=REPLACE_ME_HOSTNAME

# ── Connection target literals consumed by the bootstrap script ──
# (port + db_name should match the Terraform module defaults; override
# only if you customised them in environments/<env>/terraform.tfvars)
DB_PORT=5432
DB_NAME=inflect_compliance
REDIS_PORT=6379

# ── Secrets-Manager logical names ──
# Discoverable from `terraform output runtime_secret_names` and
# `terraform output db_secret_arn`. The bootstrap script needs both.
SECRETS_ENV_PREFIX=inflect-compliance-production
RDS_SECRET_NAME=REPLACE_ME_RDS_MANAGED_SECRET_NAME
REDIS_SECRET_NAME=inflect-compliance-production-redis-auth

# ── Redis password — REQUIRED for the compose redis container ──
# deploy/docker-compose.prod.yml runs Redis with
# `--requirepass "${REDIS_PASSWORD:?…}"`; compose ABORTS at `up` time
# if REDIS_PASSWORD is unset. This is a SECRET — do NOT commit a real
# value here. The bootstrap script (scripts/bootstrap-env-from-secrets.sh)
# resolves it from AWS Secrets Manager ($REDIS_SECRET_NAME) into
# .env.runtime alongside the authenticated REDIS_URL. If you run the
# compose stack directly, export REDIS_PASSWORD in the shell first.
# REDIS_PASSWORD=

# ── Non-secret runtime knobs ──
RATE_LIMIT_MODE=redis
STORAGE_PROVIDER=s3
AV_SCAN_MODE=permissive
SMTP_FROM=noreply@inflect.app

# ── Email delivery ──
# Resend (https://resend.com) is PREFERRED when RESEND_API_KEY is set — it uses
# Resend's HTTPS API (no SMTP egress needed). RESEND_FROM must be a
# Resend-verified sender. With neither Resend nor SMTP_HOST configured, the app
# falls back to a console sink and does NOT deliver mail (invites, verification…).
RESEND_API_KEY=        # re_… (secret)  pragma: allowlist secret
RESEND_FROM=noreply@inflect.app
# SMTP fallback (only used when RESEND_API_KEY is empty):
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=           # = your Resend API key, if you prefer the SMTP path
AI_RISK_PROVIDER=stub
AI_RISK_ENABLED=false
FILE_MAX_SIZE_BYTES=104857600

# ── OAuth client IDs (NOT secrets — these are public identifiers) ──
GOOGLE_CLIENT_ID=REPLACE_ME_GOOGLE_OAUTH_CLIENT_ID
MICROSOFT_CLIENT_ID=REPLACE_ME_MICROSOFT_OAUTH_CLIENT_ID
MICROSOFT_TENANT_ID=common

# ── Bootstrap workflow ──
# On the deploy host, after `terraform apply` completes:
#
#   1. Set the OAuth client SECRETS in AWS Secrets Manager (one-shot,
#      after first apply — Terraform creates empty placeholders):
#        aws secretsmanager put-secret-value \
#          --secret-id inflect-compliance-production-google-client-secret \
#          --secret-string '<real-google-client-secret>'
#        aws secretsmanager put-secret-value \
#          --secret-id inflect-compliance-production-microsoft-client-secret \
#          --secret-string '<real-microsoft-client-secret>'
#
#   2. Source this file's NON-secret values + run the bootstrap:
#        export $(grep -v '^#' deploy/.env.prod | xargs)
#        ./scripts/bootstrap-env-from-secrets.sh \
#          --env-prefix "$SECRETS_ENV_PREFIX" \
#          --rds-secret "$RDS_SECRET_NAME" \
#          --redis-secret "$REDIS_SECRET_NAME" \
#          --db-host "$DATABASE_HOST" --db-port "$DB_PORT" --db-name "$DB_NAME" \
#          --redis-host "$REDIS_HOST" --redis-port "$REDIS_PORT" \
#          --s3-bucket "$S3_BUCKET" --s3-region "$S3_REGION" \
#          --app-hostname "$APP_HOSTNAME" \
#          --output deploy/.env.runtime
#
#   3. docker compose -f deploy/docker-compose.prod.yml up -d
#      (compose's env_file points at deploy/.env.runtime)
